****************************************************************
* One bounded plane-1 radial numerical-floor arm.              *
*                                                              *
* The runner replaces exactly three locked template tokens.    *
* Native strict early termination remains active; MAXOUT=6 is  *
* a cap, not a request to force six iterations.                 *
****************************************************************

SEQ_BINARY TRACK_f :: FILE './initial_radial_track.bin' ;

XSM_FILE MACRO0 :: FILE './restart_macro0.xsm' ;
XSM_FILE FSOURCE :: FILE './restart_source.xsm' ;
XSM_FILE SYSTEM :: FILE './restart_system.xsm' ;
XSM_FILE TRACK :: FILE './restart_track.xsm' ;
XSM_FILE FLUX :: FILE './arm_flux.xsm' ;

MODULE FLU: END: ;

INTEGER outer_cap := 6 ;
INTEGER inner_cap := 740 ;
INTEGER free_steps := @FREE@ ;
INTEGER acc_steps := @ACCEL@ ;
REAL solver_eps := 2.5E-7 ;

ECHO "RADIAL-FLOOR-ARM-BEGIN" "@ARM@" ;
ECHO "RADIAL-FLOOR-ARM-HISTORY" "RESET" ;
ECHO "RADIAL-FLOOR-ARM-CONTROLS"
  outer_cap inner_cap solver_eps free_steps acc_steps ;

FLUX := FLU: FLUX MACRO0 TRACK TRACK_f SYSTEM FSOURCE ::
  EDIT 1 TYPE S INIT ON REBA
  EXTE <<outer_cap>> <<solver_eps>>
  UNKT <<solver_eps>>
  THER <<inner_cap>> <<solver_eps>>
  ACCE <<free_steps>> <<acc_steps>> ;

ECHO "RADIAL-FLOOR-ARM-COMPLETE" "@ARM@" ;
END: ;
QUIT "LIST" .

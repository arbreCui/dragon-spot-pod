****************************************************************
* Prepare the frozen plane-1 numerical-floor restart package.  *
*                                                              *
* This deck performs no transport solve. It reconstructs the   *
* exact frozen fission source from x0 and extracts the cap-500  *
* plane-1 flux and system from the failed Stage-4 artifact.     *
****************************************************************

XSM_FILE SNAP_SEED :: FILE './initial_snapshots.xsm' ;
XSM_FILE AX0_ARCH :: FILE './state0_axial.xsm' ;
XSM_FILE TRACK_AX :: FILE './initial_axial_track.xsm' ;
XSM_FILE CAP_ARCH :: FILE './state1_snapshots.xsm' ;

XSM_FILE RESTART_MACRO :: FILE './restart_macro0.xsm' ;
XSM_FILE RESTART_SOURCE :: FILE './restart_source.xsm' ;
XSM_FILE RESTART_SYSTEM :: FILE './restart_system.xsm' ;
XSM_FILE RESTART_TRACK :: FILE './restart_track.xsm' ;
XSM_FILE RESTART_CAP :: FILE './restart_cap.xsm' ;

LINKED_LIST SNAP TRACK MICROLIB2 FLUX MACRO0 FSOURCE SYSTEM ;

MODULE RECOVER: SPOPROJ: SPOFSRC: GREP: DELETE: END: ;

REAL k0 ;

ECHO "RADIAL-FLOOR-PREPARE-BEGIN" ;

* Reconstruct exactly the B*a0 radial input used to build the frozen source.
SNAP := RECOVER: SNAP_SEED :: ITEM 1 ;
TRACK := RECOVER: SNAP :: ITEM 3 ;
SNAP := SPOPROJ: SNAP AX0_ARCH TRACK_AX :: FIXB ;
MICROLIB2 := RECOVER: SNAP :: ITEM 1 ;
FLUX := RECOVER: SNAP :: ITEM 1 ;
GREP: AX0_ARCH :: GETVAL 'K-EFFECTIVE' 1 >>k0<< ;
MACRO0 FSOURCE := SPOFSRC: MICROLIB2 TRACK FLUX :: KEFF <<k0>> ;

RESTART_MACRO := MACRO0 ;
RESTART_SOURCE := FSOURCE ;
RESTART_TRACK := TRACK ;

MICROLIB2 FLUX SNAP := DELETE: MICROLIB2 FLUX SNAP ;

* Extract only the forensic plane-1 cap state and its actual radial system.
SNAP := RECOVER: CAP_ARCH :: ITEM 1 ;
SYSTEM := RECOVER: SNAP :: ITEM 1 ;
FLUX := RECOVER: SNAP :: ITEM 1 ;
RESTART_SYSTEM := SYSTEM ;
RESTART_CAP := FLUX ;

ECHO "RADIAL-FLOOR-PREPARE-K0" k0 ;
ECHO "RADIAL-FLOOR-PREPARE-COMPLETE" ;
END: ;
QUIT "LIST" .

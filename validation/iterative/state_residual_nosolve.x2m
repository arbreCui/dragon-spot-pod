****************************************************************
* Stage 0C runtime: canonical state and raw residual plumbing. *
* Existing axial fields are read only as a no-solve fixture.   *
* These fields are not evidence for the corrected fixed-B map. *
****************************************************************

XSM_FILE TRACK_AX :: FILE './initial_axial_track.xsm' ;
XSM_FILE MACROLIB3 :: FILE './initial_axial_macrolib.xsm' ;
XSM_FILE BASIS_REF :: FILE './basis_reference.xsm' ;
XSM_FILE SNAP_SEED :: FILE './initial_snapshots.xsm' ;
XSM_FILE AX_PREVIOUS :: FILE './state8_axial.xsm' ;
XSM_FILE AX_CURRENT :: FILE './state9_axial.xsm' ;

LINKED_LIST SNAP ;
MODULE RECOVER: SPOSTATE: SPOXCONV: SPOPROJ: GREP: END: ;

DOUBLE rrho rleak dleak ra ;
DOUBLE proj_perp ;
INTEGER proj_marker ;

SNAP := RECOVER: SNAP_SEED :: ITEM 1 ;

AX_PREVIOUS := SPOSTATE:
  AX_PREVIOUS TRACK_AX BASIS_REF MACROLIB3 :: ;
ECHO "ITERATIVE-STATE-PREVIOUS-BUILT" ;
SNAP := SPOPROJ: SNAP AX_PREVIOUS TRACK_AX :: FIXB ;
GREP: SNAP :: GETVAL 'SPOT-PROJECT' 1 >>proj_marker<< ;
GREP: SNAP :: GETVAL 'SPOT-PJ-PERP' 1 >>proj_perp<< ;
ECHO "ITERATIVE-STATE-CANONICAL-PROJECTION"
  proj_marker proj_perp ;

AX_CURRENT := SPOSTATE:
  AX_CURRENT TRACK_AX BASIS_REF MACROLIB3 :: ;
ECHO "ITERATIVE-STATE-CURRENT-BUILT" ;

AX_CURRENT := SPOXCONV: AX_CURRENT AX_PREVIOUS :: ;
GREP: AX_CURRENT :: GETVAL 'SPOT-X-RRHO' 1 >>rrho<< ;
GREP: AX_CURRENT :: GETVAL 'SPOT-X-RLEAK' 1 >>rleak<< ;
GREP: AX_CURRENT :: GETVAL 'SPOT-X-DLEAK' 1 >>dleak<< ;
GREP: AX_CURRENT :: GETVAL 'SPOT-X-RA' 1 >>ra<< ;
ECHO "ITERATIVE-HISTORICAL-STATE-DIFFERENCE" rrho rleak dleak ra ;

ECHO "ITERATIVE-STATE-NOSOLVE-COMPLETE" ;
END: ;
QUIT "LIST" .

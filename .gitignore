runs/**/SpotSnpSN.c2m
runs/**/SpotSnapBldSNT.c2m
runs/**/assertS.c2m
runs/**/rnr_cc.c2m
runs/**/rnr_interpol.c2m
runs/**/DLIB8R1_366
runs/**/DLIB8R1_370
runs/**/DLIBJ312_315
runs/**/irena_*.dat

# =====================================================================
# Source backups (kept locally, not committed)
# =====================================================================
src/*.bak
src/*.bak.*
src/*.original
src/*.podversion.bak
src/*.v1.bak


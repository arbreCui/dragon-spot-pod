# =====================================================================
# Compiled build artifacts
# =====================================================================
*.o
*.mod
*.a
*.dSYM/

# Compiled libraries / binaries from any sub-tree
**/lib/Darwin_*/
**/lib/Linux_*/
**/bin/Darwin_*/
**/bin/Linux_*/

# =====================================================================
# Dragon CLE-2000 run artifacts (regenerated by drivers; never commit)
# =====================================================================
*.l2m
*.o2m
_main001
_main002
_main003
_main004
_main005
_main006
_DUMMY
_Spot*
_Snap*
_assertS*
_rnr_cc*
_rnr_interpol*
DUMMYSQ
TRACK_f
TRACK_T_f
TRACK_FUEL_f

# Run logs and binary outputs (large; K data tracked elsewhere)
runs/**/*.log
runs/**/*.log.preopt
runs/**/*.log.O3
runs/**/*.err
runs/**/*.eps
runs/**/statepoint.*.h5
runs/**/summary.h5

# Symlinks created by run scripts (point at data/, regenerated each run)
runs/**/SpotPodItr.c2m
runs/**/SpotPodEps.c2m
runs/**/SpotPodMic.c2m
runs/**/Snap1Ring.c2m
runs/**/SnapMring.c2m
